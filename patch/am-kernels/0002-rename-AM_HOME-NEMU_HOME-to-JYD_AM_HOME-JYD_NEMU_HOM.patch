diff --git a/kernels/nemu/Makefile b/kernels/nemu/Makefile
index deb8a14..ee64136 100644
--- a/kernels/nemu/Makefile
+++ b/kernels/nemu/Makefile
@@ -7,25 +7,25 @@ $(error Only support with NEMU)
 endif
 
 TMPDEFCONFIG = tmp_defconfig
-TMPDEFCONFIG_FILE = $(NEMU_HOME)/configs/$(TMPDEFCONFIG)
+TMPDEFCONFIG_FILE = $(JYD_NEMU_HOME)/configs/$(TMPDEFCONFIG)
 
 all:
 	$(MAKE) save_config
 	$(MAKE) build_am
 	$(MAKE) restore_config
-	$(MAKE) -C $(NEMU_HOME) run IMG=$(NEMU_HOME)/build/$(ISA)-nemu-interpreter-$(ARCH).bin
+	$(MAKE) -C $(JYD_NEMU_HOME) run IMG=$(JYD_NEMU_HOME)/build/$(ISA)-nemu-interpreter-$(ARCH).bin
 
 save_config:
-	$(MAKE) -C $(NEMU_HOME) savedefconfig
-	mv $(NEMU_HOME)/configs/defconfig $(TMPDEFCONFIG_FILE)
+	$(MAKE) -C $(JYD_NEMU_HOME) savedefconfig
+	mv $(JYD_NEMU_HOME)/configs/defconfig $(TMPDEFCONFIG_FILE)
 
 build_am:
-	$(MAKE) -C $(NEMU_HOME) $(ISA)-am_defconfig
-	$(MAKE) -C $(NEMU_HOME) ARCH=$(ARCH) mainargs=$(mainargs) || \
+	$(MAKE) -C $(JYD_NEMU_HOME) $(ISA)-am_defconfig
+	$(MAKE) -C $(JYD_NEMU_HOME) ARCH=$(ARCH) mainargs=$(mainargs) || \
 		($(MAKE) restore_config; false)
 
 restore_config:
-	$(MAKE) -C $(NEMU_HOME) ARCH=$(ARCH) $(TMPDEFCONFIG)
+	$(MAKE) -C $(JYD_NEMU_HOME) ARCH=$(ARCH) $(TMPDEFCONFIG)
 	rm $(TMPDEFCONFIG_FILE)
 
 .PHONY: all save_config build_am restore_config
